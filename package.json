{
  "version": "1.0.0",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "forms",
    "formflow",
    "form-builder"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build && node scripts/check-ee-bundled.mjs",
    "check:ee": "node scripts/check-ee-bundled.mjs",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json",
    "test:unit": "tsc server/src/ee/license/__tests__/no-key-submission.test.ts --rootDir . --outDir /tmp/sf-test-out --module commonjs --target es2020 --moduleResolution node --esModuleInterop --skipLibCheck && node /tmp/sf-test-out/server/src/ee/license/__tests__/no-key-submission.test.js",
    "prepublishOnly": "npm run build && npm run verify",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "pdfkit": "^0.15.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^5.4.0",
    "@strapi/strapi": "^5.33.0",
    "@strapi/typescript-utils": "^5.33.0",
    "@types/pdfkit": "^0.13.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.6.2",
    "react-router-dom": "^6.30.2",
    "styled-components": "^6.1.19",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^5.4.0",
    "@strapi/strapi": "^5.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.30.2",
    "styled-components": "^6.1.19"
  },
  "strapi": {
    "kind": "plugin",
    "name": "formflow",
    "displayName": "FormFlow",
    "description": "FormFlow is a flexible Strapi v5 plugin for creating dynamic forms with configurable fields, validations, and submissions, designed for headless and API-first projects."
  },
  "name": "strapi-plugin-formflow",
  "description": "FormFlow is a flexible Strapi v5 plugin for creating dynamic forms with configurable fields, validations, and submissions, designed for headless and API-first projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hrahimi270/strapi-plugin-formflow.git"
  },
  "homepage": "https://github.com/hrahimi270/strapi-plugin-formflow#readme",
  "bugs": {
    "url": "https://github.com/hrahimi270/strapi-plugin-formflow/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Bardiya <hrahimi270@gmail.com>"
}
